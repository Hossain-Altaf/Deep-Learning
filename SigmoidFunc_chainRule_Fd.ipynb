import numpy as np
import matplotlib.pyplot as plt

# ── Activation & derivatives 
def sigmoid(z):       return 1 / (1 + np.exp(-z))
def sigmoid_prime(a): return a * (1 - a)          # da/dz expressed via a

# ── Loss functions & dL/da 
def mse(a, y):        return (a - y) ** 2
def dL_da_mse(a, y):  return 2 * (a - y)

def bce(a, y, eps=1e-12):
    a = np.clip(a, eps, 1 - eps)
    return -(y * np.log(a) + (1 - y) * np.log(1 - a))

def dL_da_bce(a, y, eps=1e-12):
    a = np.clip(a, eps, 1 - eps)
    return (a - y) / (a * (1 - a))                # cancels with sigmoid_prime → a−y

# ── Chain rule: one step, one weight 
x, w, b, y_true = 2.0, 0.2, 0.0, 1.0
z     = w * x + b
a     = sigmoid(z)

# three links
dLda  = dL_da_mse(a, y_true)   # dL/da
dadz  = sigmoid_prime(a)        # da/dz  (the link Lesson 2 skipped)
dzdw  = x                       # dz/dw

dL_dw = dLda * dadz * dzdw
dL_db = dLda * dadz             # dz/db = 1

print("── Single weight, chain rule (MSE + sigmoid) ──")
print(f"  z={z:.4f}  a={a:.4f}  L={mse(a,y_true):.4f}")
print(f"  dL/da={dLda:.4f}  da/dz={dadz:.4f}  dz/dw={dzdw}")
print(f"  dL/dw = {dL_dw:.4f}   dL/db = {dL_db:.4f}")

# ── Multiple inputs: δ computed once, fanned out
x1, x2   = 2.0, -1.0
w1, w2   = 0.3,  0.5
b, y_true = 0.1, 1.0

z    = w1*x1 + w2*x2 + b
a    = sigmoid(z)
delta = dL_da_mse(a, y_true) * sigmoid_prime(a)   # δ = dL/dz

print("\n── Multiple inputs, δ fan-out ──")
print(f"  δ={delta:.4f}   ∂L/∂w1={delta*x1:.4f}   ∂L/∂w2={delta*x2:.4f}   ∂L/∂b={delta:.4f}")

# ── BCE cancellation: δ = a − y 
a_conf = 0.02    # confidently wrong prediction
y_conf = 1.0
delta_mse = dL_da_mse(a_conf, y_conf) * sigmoid_prime(a_conf)
delta_bce = a_conf - y_conf            # a(1−a) cancels with dL/da_bce

print("\n── BCE vs MSE δ on a confidently-wrong prediction ──")
print(f"  a={a_conf}, y={y_conf}")
print(f"  δ (MSE) = {delta_mse:.4f}  ← tiny")
print(f"  δ (BCE) = {delta_bce:.4f}  ← proportional to error")

# ── Gradient descent step 
x, w, b, y_true, lr = 2.0, 0.2, 0.0, 1.0, 0.1
z = w*x + b;  a = sigmoid(z)
delta = dL_da_mse(a, y_true) * sigmoid_prime(a)
w_new = w - lr * delta * x
b_new = b - lr * delta
a_new = sigmoid(w_new*x + b_new)

print("\n── One gradient-descent step ──")
print(f"  before: w={w:.4f}  loss={mse(a,y_true):.4f}")
print(f"  after:  w={w_new:.4f}  loss={mse(a_new,y_true):.4f}")

# ── Plots 
z_range = np.linspace(-6, 6, 300)
a_range = sigmoid(z_range)

fig, axes = plt.subplots(1, 3, figsize=(13, 4))
fig.suptitle("Lesson 03 · Chain Rule", fontsize=13, fontweight='bold')

# Plot 1: sigmoid + derivative
axes[0].plot(z_range, a_range,              color='#185FA5', lw=2, label='σ(z)')
axes[0].plot(z_range, sigmoid_prime(a_range), color='#3C3489', lw=2, label="σ′(z)=a(1−a)")
axes[0].axhline(0.5, color='gray', lw=0.7, ls='--')
axes[0].set_title("Sigmoid & its derivative"); axes[0].legend(fontsize=9)
axes[0].set_xlabel("z"); axes[0].spines[['top','right']].set_visible(False)

# Plot 2: loss landscape L(w)
w_range = np.linspace(-2, 2, 300)
x0, b0, y0 = 2.0, 0.0, 1.0
L_vals = mse(sigmoid(w_range * x0 + b0), y0)
axes[1].plot(w_range, L_vals, color='#185FA5', lw=2)
axes[1].set_title("Loss landscape L(w)"); axes[1].set_xlabel("w"); axes[1].set_ylabel("L")
axes[1].spines[['top','right']].set_visible(False)

# Plot 3: BCE vs MSE δ
a_r = np.linspace(0.01, 0.99, 300)
axes[2].plot(a_r, dL_da_mse(a_r, 1.0) * sigmoid_prime(a_r),
             color='#185FA5', lw=2, label='MSE δ')
axes[2].plot(a_r, a_r - 1.0, color='#3C3489', lw=2, ls='--', label='BCE δ = a−y')
axes[2].axvline(0.5, color='gray', lw=0.7, ls=':')
axes[2].set_title("BCE vs MSE gradient"); axes[2].set_xlabel("a (prediction)")
axes[2].set_ylabel("δ = dL/dz"); axes[2].legend(fontsize=9)
axes[2].spines[['top','right']].set_visible(False)

plt.tight_layout()
plt.show()
